# Configuration locale de CH-Api-GateWay — copier vers .env (jamais commité).
# Ces variables surchargent les valeurs du config.yaml via ApplyEnvOverrides().

# Port d'écoute du Gateway
PORT=8180

# Environnement d'exécution : development (permissif) ou production (durci).
# En production, le wildcard "*" dans CORS_ALLOWED_ORIGINS est refusé au démarrage.
GATEWAY_ENV=development

# Endpoint de validation des tokens (CH-Api-Authenticator)
AUTH_SERVICE_URL=http://localhost:8181/validate

# Page de login du portail d'authentification (redirection navigateur 302)
AUTH_FRONT_URL=http://localhost:3200/login

# Origines CORS autorisées (séparées par des virgules).
# Lister tous les portails front qui appellent le Gateway.
CORS_ALLOWED_ORIGINS=http://localhost:3200,http://localhost:3201
